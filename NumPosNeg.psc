// Programa para saber si un numero es positivo o negativo
Algoritmo NumPosNeg
	// Entrada
	Escribir '===NUMEROS POSITIVOS Y NEGATIVOS==='
	Definir n Como Entero
	Escribir 'Escribe un numero entero: 'Sin Saltar
	Leer n
	// Proceso
	Si n>=0 Entonces
		Escribir 'Numero Positivo'
	SiNo
		Escribir 'Numero Negativo'
	FinSi
	// salida
FinAlgoritmo
